declare i32 @a [2]
define i32 @main()
{
	declare i32 %l0
	declare i32* %l1
	declare i32* %l2
	declare i32 %l3
	declare i32 %l4
	declare i32 %l5
	declare i32 %t6
	declare i32* %t7
	declare i32 %t8
	declare i32* %t9
	entry
	%l0 = 0
	%l1 = @a
	%t6 = mul 0, 4
	%t7 = add %l1, %t6
	%l4 = 1
	%l2 = @a
	%t8 = mul 0, 4
	%t9 = add %l2, %t8
	%l3 = %l5
	%l0 = %l3
	br label .L10
.L10:
	exit %l0
}
